; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="2.5D"
run/main_scene="uid://ty0s7a3cfm1m"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"
run/physics_ticks_per_second=60
run/vsync/vsync_mode=1
run/quality/msaa_3d=1
run/quality/use_taa=false

[autoload]

Debug="*res://scripts/utils/debug.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/Asset_Drawer/plugin.cfg", "res://addons/func_godot/plugin.cfg", "res://addons/instant-realistic-light/plugin.cfg")

[filesystem]

import/blender/enabled=false

